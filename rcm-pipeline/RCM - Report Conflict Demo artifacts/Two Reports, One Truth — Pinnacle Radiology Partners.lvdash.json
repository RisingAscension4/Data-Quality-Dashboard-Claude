              "encodings": {
                "x": {
                  "fieldName": "root_cause",
                  "axis": {
                    "hideTitle": true,
                    "labelAngle": 45
                  },
                  "displayName": "DQ Dimension",
                  "scale": {
                    "type": "categorical",
                    "sort": {
                      "by": "y-reversed"
                    }
                  }
                },
                "y": {
                  "fieldName": "Absolute Gap",
