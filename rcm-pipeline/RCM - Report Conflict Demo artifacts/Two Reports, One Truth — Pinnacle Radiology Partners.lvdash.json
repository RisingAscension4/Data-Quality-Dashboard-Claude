{
  "datasets": [
    {
      "name": "report_divergence",
      "displayName": "Report Divergence",
      "queryLines": [
        "SELECT\n",
        "  CASE\n",
        "    WHEN kpi LIKE 'Total Charges%' THEN CONCAT('Total Charges (', CHR(36), ' in millions)')\n",
        "    WHEN kpi LIKE 'Net Revenue%' THEN CONCAT('Net Revenue (', CHR(36), ' in millions)')\n",
        "    ELSE kpi\n",
        "  END as kpi,\n",
        "  report_a_cfo,\n",
        "  report_b_revops,\n",
        "  divergence,\n",
        "  root_cause,\n",
        "  explanation\n",
        "FROM\n",
        "  serverless_stable_jc9zgx_catalog.radiology_revenue_cycle.v_report_divergence"
      ],
      "columns": [
        {
          "displayName": "Absolute Gap",
          "description": "",
          "expression": "ABS(`divergence`)"
        }
      ]
    },
    {
      "name": "report_b_revops",
      "displayName": "Report B - RevOps Performance",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  serverless_stable_jc9zgx_catalog.radiology_revenue_cycle.v_revops_performance"
      ]
    },
    {
      "name": "report_a_cfo",
      "displayName": "Report A - CFO Summary",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  serverless_stable_jc9zgx_catalog.radiology_revenue_cycle.v_cfo_monthly_summary"
      ]
    }
  ],
