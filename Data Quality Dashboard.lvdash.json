      "queryLines": [
        "SELECT 'Completeness' AS dimension, completeness_score AS score FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest UNION ALL SELECT 'Accuracy', accuracy_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest UNION ALL SELECT 'Validity', validity_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest UNION ALL SELECT 'Consistency', consistency_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest UNION ALL SELECT 'Uniqueness', uniqueness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest UNION ALL SELECT 'Timeliness', timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest order by score ASC"
      ]
    },
    {
      "name": "f733b910",
      "displayName": "Tables Below Threshold",
      "queryLines": [
        "SELECT COUNT(*) AS cnt FROM serverless_stable_jc9zgx_catalog.data_quality.v_table_scores_latest WHERE overall_score < effective_threshold_min"
      ]
    },
    {
      "name": "33589ff4",
