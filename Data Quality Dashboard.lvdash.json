    {
      "name": "24596ed1",
      "displayName": "Org KPI Latest",
      "queryLines": [
        "SELECT overall_score, completeness_score, accuracy_score, validity_score, consistency_score, uniqueness_score, timeliness_score, tables_below_threshold, pct_assets_monitored, total_tables, total_domains FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest"
      ]
    },
    {
      "name": "466718b6",
      "displayName": "Org KPI Latest",
      "queryLines": [
        "SELECT overall_score, completeness_score, accuracy_score, validity_score, consistency_score, uniqueness_score, timeliness_score, tables_below_threshold, pct_assets_monitored, total_tables, total_domains FROM serverless_stable_jc9zgx_catalog.data_quality.v_org_score_latest"
      ]
    },
    {
      "name": "14fb39c1",
      "displayName": "Org 30-Day Trend",
      "queryLines": [
        "SELECT \n",
        "  dst.run_timestamp, \n",
        "  ROUND(AVG(dst.overall_score),2) AS overall_score, \n",
        "  ROUND(AVG(dst.completeness_score),2) AS completeness_score, \n",
        "  ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, \n",
        "  ROUND(AVG(dst.validity_score),2) AS validity_score, \n",
        "  ROUND(AVG(dst.consistency_score),2) AS consistency_score, \n",
        "  ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, \n",
        "  ROUND(AVG(dst.timeliness_score),2) AS timeliness_score,\n",
        "  org.dq_threshold_min,\n",
        "  org.dq_threshold_warning,\n",
        "  org.dq_threshold_critical\n",
        "FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst\n",
        "CROSS JOIN serverless_stable_jc9zgx_catalog.data_quality.organization org\n",
        "GROUP BY dst.run_timestamp, org.dq_threshold_min, org.dq_threshold_warning, org.dq_threshold_critical\n",
        "ORDER BY dst.run_timestamp"
      ]
    },
    {
      "name": "801238e1",
      "displayName": "Pct Columns Failing",
      "queryLines": [
        "SELECT\n",
        "  COUNT(DISTINCT\n",
        "    CASE\n",
        "      WHEN NOT crr.passed THEN dc.column_id\n",
        "    END\n",
        "  ) AS failing_columns,\n",
        "  COUNT(DISTINCT dc.column_id) AS total_monitored_columns,\n",
        "  ROUND(\n",
        "    100.0\n",
        "      * COUNT(DISTINCT\n",
        "        CASE\n",
        "          WHEN NOT crr.passed THEN dc.column_id\n",
        "        END\n",
        "      )\n",
        "      / COUNT(DISTINCT dc.column_id),\n",
        "    2\n",
        "  ) AS pct_columns_failing\n",
        "FROM\n",
        "  serverless_stable_jc9zgx_catalog.data_quality.column_rule_result crr\n",
        "    JOIN serverless_stable_jc9zgx_catalog.data_quality.column_rule_assignment cra\n",
        "      ON crr.assignment_id = cra.assignment_id\n",
        "    JOIN serverless_stable_jc9zgx_catalog.data_quality.dq_column dc\n",
        "      ON cra.column_id = dc.column_id\n",
        "    JOIN serverless_stable_jc9zgx_catalog.data_quality.v_latest_run lr\n",
        "      ON crr.run_id = lr.latest_run_id"
      ]
    },
    {
      "name": "2da9cd89",
      "displayName": "Domain 30-Day Change",
      "queryLines": [
        "WITH ranked AS (\n",
        "  SELECT\n",
        "    domain_name,\n",
        "    overall_score,\n",
        "    run_timestamp,\n",
        "    ROW_NUMBER() OVER (PARTITION BY domain_name ORDER BY run_timestamp ASC) AS rn_first,\n",
        "    ROW_NUMBER() OVER (PARTITION BY domain_name ORDER BY run_timestamp DESC) AS rn_last\n",
        "  FROM\n",
        "    serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend\n",
        ")\n",
        "SELECT\n",
        "  f.domain_name,\n",
        "  f.overall_score AS first_score,\n",
        "  l.overall_score AS latest_score,\n",
        "  ROUND(l.overall_score - f.overall_score, 2) AS score_change\n",
        "FROM\n",
        "  ranked f\n",
        "    JOIN ranked l\n",
        "      ON f.domain_name = l.domain_name\n",
        "      AND l.rn_last = 1\n",
        "WHERE\n",
        "  f.rn_first = 1"
      ]
    },
    {
      "name": "798ba06b",
      "displayName": "Org Trend Unpivoted",
      "queryLines": [
        "SELECT run_timestamp, 'Overall' AS dimension, overall_score AS score FROM (SELECT dst.run_timestamp, ROUND(AVG(dst.overall_score),2) AS overall_score, ROUND(AVG(dst.completeness_score),2) AS completeness_score, ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, ROUND(AVG(dst.validity_score),2) AS validity_score, ROUND(AVG(dst.consistency_score),2) AS consistency_score, ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, ROUND(AVG(dst.timeliness_score),2) AS timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst GROUP BY dst.run_timestamp ORDER BY dst.run_timestamp) UNION ALL SELECT run_timestamp, 'Completeness', completeness_score FROM (SELECT dst.run_timestamp, ROUND(AVG(dst.overall_score),2) AS overall_score, ROUND(AVG(dst.completeness_score),2) AS completeness_score, ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, ROUND(AVG(dst.validity_score),2) AS validity_score, ROUND(AVG(dst.consistency_score),2) AS consistency_score, ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, ROUND(AVG(dst.timeliness_score),2) AS timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst GROUP BY dst.run_timestamp ORDER BY dst.run_timestamp) UNION ALL SELECT run_timestamp, 'Accuracy', accuracy_score FROM (SELECT dst.run_timestamp, ROUND(AVG(dst.overall_score),2) AS overall_score, ROUND(AVG(dst.completeness_score),2) AS completeness_score, ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, ROUND(AVG(dst.validity_score),2) AS validity_score, ROUND(AVG(dst.consistency_score),2) AS consistency_score, ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, ROUND(AVG(dst.timeliness_score),2) AS timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst GROUP BY dst.run_timestamp ORDER BY dst.run_timestamp) UNION ALL SELECT run_timestamp, 'Validity', validity_score FROM (SELECT dst.run_timestamp, ROUND(AVG(dst.overall_score),2) AS overall_score, ROUND(AVG(dst.completeness_score),2) AS completeness_score, ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, ROUND(AVG(dst.validity_score),2) AS validity_score, ROUND(AVG(dst.consistency_score),2) AS consistency_score, ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, ROUND(AVG(dst.timeliness_score),2) AS timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst GROUP BY dst.run_timestamp ORDER BY dst.run_timestamp) UNION ALL SELECT run_timestamp, 'Consistency', consistency_score FROM (SELECT dst.run_timestamp, ROUND(AVG(dst.overall_score),2) AS overall_score, ROUND(AVG(dst.completeness_score),2) AS completeness_score, ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, ROUND(AVG(dst.validity_score),2) AS validity_score, ROUND(AVG(dst.consistency_score),2) AS consistency_score, ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, ROUND(AVG(dst.timeliness_score),2) AS timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst GROUP BY dst.run_timestamp ORDER BY dst.run_timestamp) UNION ALL SELECT run_timestamp, 'Uniqueness', uniqueness_score FROM (SELECT dst.run_timestamp, ROUND(AVG(dst.overall_score),2) AS overall_score, ROUND(AVG(dst.completeness_score),2) AS completeness_score, ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, ROUND(AVG(dst.validity_score),2) AS validity_score, ROUND(AVG(dst.consistency_score),2) AS consistency_score, ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, ROUND(AVG(dst.timeliness_score),2) AS timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst GROUP BY dst.run_timestamp ORDER BY dst.run_timestamp) UNION ALL SELECT run_timestamp, 'Timeliness', timeliness_score FROM (SELECT dst.run_timestamp, ROUND(AVG(dst.overall_score),2) AS overall_score, ROUND(AVG(dst.completeness_score),2) AS completeness_score, ROUND(AVG(dst.accuracy_score),2) AS accuracy_score, ROUND(AVG(dst.validity_score),2) AS validity_score, ROUND(AVG(dst.consistency_score),2) AS consistency_score, ROUND(AVG(dst.uniqueness_score),2) AS uniqueness_score, ROUND(AVG(dst.timeliness_score),2) AS timeliness_score FROM serverless_stable_jc9zgx_catalog.data_quality.v_domain_score_trend dst GROUP BY dst.run_timestamp ORDER BY dst.run_timestamp)"
      ]
    },
    {
      "name": "9f6037b5",
      "displayName": "Most Egregious Tables",
      "queryLines": [
        "SELECT\n",
        "  table_name,\n",
        "  domain_name,\n",
